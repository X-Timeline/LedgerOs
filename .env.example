# Copy this file to ".env" and fill in your real values.
# Find these in Supabase Dashboard -> Project Settings -> API
#
# Only the anon/public key goes here — it's safe for the browser.
# NEVER put the service_role key in this file or anywhere in frontend code.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# The Express backend (see ledgeros-backend/). Defaults to localhost for
# local dev — update this once the backend is deployed somewhere real
# (Render, Railway, etc. — it needs its own persistent host, Vercel/static
# hosting won't run it).
VITE_API_URL=http://localhost:4000
